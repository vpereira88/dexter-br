# ─────────────────────────────────────────────────────────────────
# Gateway WhatsApp — Controle de Acesso
# ─────────────────────────────────────────────────────────────────

# Número do ADMIN (formato E.164: +5511999999999)
# O admin tem acesso irrestrito: pode enviar comandos em qualquer
# grupo ou conversa, mesmo que não esteja na allowlist.
# Use !id em qualquer grupo para obter o ID e liberá-lo.
DEXTER_ADMIN_PHONE=+5511999999999

# Contatos liberados para mensagens diretas (DM), separados por vírgula.
# Exemplo: +5511999999999,+5511888888888
# Se vazio, o bot ignora todas as DMs de números não listados.
DEXTER_ALLOW_PHONES=+5511999999999

# IDs dos grupos liberados, separados por vírgula.
# Para obter o ID de um grupo, envie !id dentro do grupo como admin.
# Exemplo: 120363407692865732@g.us,120363407692865733@g.us
DEXTER_ALLOW_GROUPS=SEU_GRUPO_ID@g.us

# Política para mensagens diretas: allowlist | open | disabled
# allowlist = apenas DEXTER_ALLOW_PHONES (recomendado)
# open      = aceita DMs de qualquer número
# disabled  = ignora todas as DMs
DEXTER_DM_POLICY=allowlist

# Política para grupos: allowlist | open | disabled
# allowlist = apenas DEXTER_ALLOW_GROUPS (recomendado)
# open      = aceita mensagens de qualquer grupo
# disabled  = ignora todos os grupos (padrão)
DEXTER_GROUP_POLICY=allowlist

# ─────────────────────────────────────────────────────────────────
# LLM API Keys
OPENAI_API_KEY=your-api-key
ANTHROPIC_API_KEY=your-api-key
GOOGLE_API_KEY=your-api-key
XAI_API_KEY=your-api-key
OPENROUTER_API_KEY=your-api-key
MOONSHOT_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Stock Market API Key
FINANCIAL_DATASETS_API_KEY=your-api-key

# Web Search API Keys (Exa → Perplexity → Tavily)
EXASEARCH_API_KEY=your-api-key
PERPLEXITY_API_KEY=your-api-key
TAVILY_API_KEY=your-api-key

# LangSmith 
LANGSMITH_API_KEY=your-api-key
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=dexter
LANGSMITH_TRACING=true
