{
  "_comment": [
    "Configuração avançada do gateway. A maioria das configurações de acesso",
    "pode ser feita diretamente no .env (DEXTER_ADMIN_PHONE, DEXTER_ALLOW_PHONES,",
    "DEXTER_ALLOW_GROUPS, DEXTER_DM_POLICY, DEXTER_GROUP_POLICY).",
    "Copie este arquivo para ~/.dexter/gateway.json apenas se precisar de",
    "configurações avançadas como múltiplas contas ou bindings customizados."
  ],
  "gateway": {
    "accountId": "default",
    "logLevel": "info"
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "accounts": {
        "default": {
          "_comment": "Políticas de acesso — preferir variáveis de ambiente no .env",
          "dmPolicy": "allowlist",
          "groupPolicy": "allowlist",
          "groupAllowFrom": [],
          "sendReadReceipts": true
        }
      }
    }
  },
  "_bindings_comment": "Roteamento (bindings) é OPCIONAL. Se omitido, todas as mensagens vão para o agente 'default'. Configure acesso exclusivamente via .env (DEXTER_ALLOW_PHONES, DEXTER_ALLOW_GROUPS, DEXTER_DM_POLICY, DEXTER_GROUP_POLICY)."
}
